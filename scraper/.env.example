# Copia este archivo como  .env  (en la misma carpeta scraper/) y completá tus datos.
# El archivo .env está en .gitignore y NUNCA se sube al repositorio.

# Credenciales del portal de socios Intcomex Costa Rica
INTCOMEX_USER=tu_usuario_o_email
INTCOMEX_PASS=tu_contraseña
INTCOMEX_CODE=@Enterprise2025

# URL base de la tienda (normalmente no hace falta cambiarla)
INTCOMEX_BASE=https://store.intcomex.com/es-XCR/Home
